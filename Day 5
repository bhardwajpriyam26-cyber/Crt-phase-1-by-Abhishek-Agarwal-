//Problem 1 
//Pattern printing
# include<iostream>
using namespace std;

int main(){
    int n=5;
    //upper triangle
    for(int i=1;i<=n;i++){
        for(int j=1;j<=i;j++){
            cout<<"*";
        }
        cout<<endl;
    }
    //lower triangle
    for(int i=n-1;i>=1;i--){
        for(int j=1;j<=i;j++){
            cout<<"*";
        }
        cout<<endl;
    }
    return 0;
}


