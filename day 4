//problem --4
//print right angle rectangle

#include<iostream>
using namespace std;

int main(){
    for(int i = 1; i <= 5; i++){
        for(int j=1;j<=i;j++){
            cout<<" *";
        }
        cout<<"\n";
    }
}


//problem --5
//print motion square

#include<iostream>
using namespace std;

int main(){
    for(int i = 1; i <= 5; i++){
        for(int j=1;j<=5;j++){
            cout<<" ";
            if(i==1 || i== 5|| j==1 || j==5){
                cout<<"*";
              }else{
                  cout<<" ";
              }
        }
        cout<<"\n";
    }
}
